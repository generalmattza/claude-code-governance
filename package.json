{
  "name": "claude-code-security",
  "version": "0.1.0-alpha.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20.10.0" },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs",
    "format": "prettier --write .",
    "typecheck": "pnpm -r --parallel typecheck",
    "build:settings": "pnpm --filter @bitsummit/ccsec-cli build && node packages/cli/bin/ccsec.js compile --profile baseline --out packages/settings/compiled/baseline.json --target user --os macos --settings-root packages/settings",
    "gen:hook-docs": "node scripts/gen-hook-docs.mjs",
    "gen:coverage-matrix": "node scripts/gen-coverage-matrix.mjs",
    "gen:docs": "pnpm gen:hook-docs && pnpm gen:coverage-matrix"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "@vitest/coverage-v8": "^1.5.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
